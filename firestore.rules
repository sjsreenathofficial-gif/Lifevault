rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only read/write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Documents: users can only access their own documents
    match /documents/{docId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Family members: users can only access their own family members
    match /familyMembers/{memberId} {
      allow read, write: if request.auth != null && 
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.resource == null || request.resource.data.userId == request.auth.uid);
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // Share links: owners can manage, anyone can read (for shared access)
    match /shareLinks/{linkId} {
      allow read: if true; // Public read for share link verification
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if true; // Allow view count increment
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
